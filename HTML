<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Privacy Policy — SportTrack.ai</title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500;600;700&family=Barlow+Condensed:wght@600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --gold: #F0A500;
      --gold-light: #FFF8E7;
      --gold-mid: #C98A00;
      --ink: #111111;
      --ink-mid: #444444;
      --ink-muted: #888888;
      --bg: #F5F5F3;
      --surface: #FFFFFF;
      --rule: #E8E6E0;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Barlow', system-ui, sans-serif;
      background: var(--bg);
      color: var(--ink);
      font-size: 16px;
      line-height: 1.7;
    }

    /* ── Top nav bar ── */
    .topbar {
      background: #fff;
      border-bottom: 1px solid var(--rule);
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 clamp(1.5rem, 5vw, 4rem);
      position: sticky;
      top: 0;
      z-index: 200;
      box-shadow: 0 1px 8px rgba(0,0,0,.06);
    }

    .topbar-logo {
      height: 30px;
      display: block;
    }

    .topbar-badge {
      font-size: .68rem;
      font-weight: 700;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--gold-mid);
      background: var(--gold-light);
      border: 1px solid rgba(240,165,0,.3);
      padding: .28rem .75rem;
      border-radius: 99px;
    }

    /* ── Banner ── */
    .banner-wrap {
      width: 100%;
      max-height: 220px;
      overflow: hidden;
      display: block;
      line-height: 0;
    }

    .banner-wrap img {
      width: 100%;
      height: 220px;
      object-fit: cover;
      object-position: center 30%;
      display: block;
    }

    /* ── Page title strip ── */
    .title-strip {
      background: #fff;
      border-bottom: 3px solid var(--gold);
      padding: 2rem clamp(1.5rem, 5vw, 4rem);
    }

    .title-strip-inner {
      max-width: 1140px;
      margin: 0 auto;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .title-eyebrow {
      font-size: .7rem;
      font-weight: 700;
      letter-spacing: .16em;
      text-transform: uppercase;
      color: var(--gold-mid);
      margin-bottom: .5rem;
      display: flex;
      align-items: center;
      gap: .5rem;
    }

    .title-eyebrow::before {
      content: '';
      display: block;
      width: 22px;
      height: 2px;
      background: var(--gold);
      border-radius: 2px;
    }

    .title-strip h1 {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: clamp(2rem, 4vw, 2.8rem);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .02em;
      color: var(--ink);
      line-height: 1.05;
    }

    .title-strip h1 span { color: var(--gold); }

    .title-meta {
      font-size: .82rem;
      color: var(--ink-muted);
      text-align: right;
    }

    .title-meta strong { color: var(--ink-mid); display: block; }

    /* ── Layout ── */
    .page-wrap {
      max-width: 1140px;
      margin: 0 auto;
      padding: 2.5rem clamp(1.5rem, 5vw, 4rem) 5rem;
      display: grid;
      grid-template-columns: 240px 1fr;
      gap: 2.25rem;
      align-items: start;
    }

    /* ── TOC ── */
    .toc {
      position: sticky;
      top: 76px;
      background: var(--surface);
      border: 1px solid var(--rule);
      border-top: 3px solid var(--gold);
      border-radius: 0 0 12px 12px;
      padding: 1.4rem;
    }

    .toc-title {
      font-size: .65rem;
      font-weight: 700;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin-bottom: .9rem;
    }

    .toc ol { list-style: none; counter-reset: toc; }
    .toc ol li { counter-increment: toc; }

    .toc ol li a {
      display: flex;
      gap: .55rem;
      align-items: baseline;
      text-decoration: none;
      font-size: .79rem;
      font-weight: 400;
      color: var(--ink-mid);
      padding: .26rem .4rem;
      border-radius: 5px;
      transition: background .14s, color .14s;
    }

    .toc ol li a::before {
      content: counter(toc, decimal-leading-zero);
      font-size: .63rem;
      color: var(--gold);
      font-weight: 700;
      flex-shrink: 0;
    }

    .toc ol li a:hover {
      background: var(--gold-light);
      color: var(--gold-mid);
    }

    .toc-rule { border: none; border-top: 1px solid var(--rule); margin: 1.1rem 0; }

    .toc-contact { font-size: .76rem; color: var(--ink-muted); line-height: 1.6; }
    .toc-contact strong { color: var(--ink); display: block; margin-bottom: .25rem; font-size: .78rem; }
    .toc-contact a { color: var(--gold-mid); text-decoration: none; }
    .toc-contact a:hover { text-decoration: underline; }

    /* ── Policy sections ── */
    .policy-section {
      background: var(--surface);
      border: 1px solid var(--rule);
      border-radius: 12px;
      padding: clamp(1.25rem, 3.5vw, 2rem);
      margin-bottom: 1.1rem;
    }

    .section-header {
      display: flex;
      align-items: center;
      gap: .8rem;
      margin-bottom: 1.1rem;
      padding-bottom: .9rem;
      border-bottom: 1px solid var(--rule);
    }

    .section-num {
      background: var(--gold);
      color: #fff;
      width: 28px; height: 28px;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: .67rem;
      font-weight: 700;
      flex-shrink: 0;
    }

    .policy-section h2 {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1.2rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .04em;
      color: var(--ink);
    }

    .policy-section p {
      color: var(--ink-mid);
      margin-bottom: .8rem;
      font-size: .93rem;
    }

    .policy-section p:last-child { margin-bottom: 0; }

    .policy-section h3 {
      font-size: .74rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .12em;
      color: var(--gold-mid);
      margin: 1.4rem 0 .45rem;
    }

    .policy-section ul, .policy-section ol {
      padding-left: 1.15rem;
      color: var(--ink-mid);
      font-size: .93rem;
      margin-bottom: .8rem;
    }

    .policy-section li { margin-bottom: .3rem; }
    .policy-section a { color: var(--gold-mid); text-decoration: none; }
    .policy-section a:hover { text-decoration: underline; }

    .highlight-box {
      background: var(--gold-light);
      border-left: 3px solid var(--gold);
      border-radius: 0 8px 8px 0;
      padding: .85rem 1.1rem;
      margin: 1rem 0;
      font-size: .9rem;
      color: var(--ink-mid);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: .87rem;
      margin: 1rem 0;
      border-radius: 8px;
      overflow: hidden;
      border: 1px solid var(--rule);
    }

    thead tr { background: var(--gold-light); }
    thead th {
      text-align: left;
      padding: .55rem .85rem;
      font-size: .68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .1em;
      color: var(--gold-mid);
      border-bottom: 2px solid rgba(240,165,0,.25);
    }

    tbody tr { border-bottom: 1px solid var(--rule); }
    tbody td { padding: .6rem .85rem; color: var(--ink-mid); vertical-align: top; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: #FAFAF8; }

    .pill {
      display: inline-flex;
      align-items: center;
      background: var(--gold-light);
      color: var(--gold-mid);
      font-size: .72rem;
      font-weight: 600;
      padding: .22rem .65rem;
      border-radius: 99px;
      margin: .15rem;
      border: 1px solid rgba(240,165,0,.3);
    }

    .pills-row { display: flex; flex-wrap: wrap; margin: .7rem 0 1rem; }

    /* ── Footer ── */
    footer {
      background: var(--ink);
      color: rgba(255,255,255,.45);
      padding: 2.5rem 1.5rem;
      text-align: center;
      font-size: .8rem;
      line-height: 1.9;
    }

    footer img.footer-logo {
      height: 26px;
      display: block;
      margin: 0 auto 1.1rem;
      border-radius: 4px;
      opacity: .85;
    }

    footer a { color: var(--gold); text-decoration: none; }
    footer a:hover { text-decoration: underline; }

    @media (max-width: 780px) {
      .page-wrap { grid-template-columns: 1fr; }
      .toc { position: static; }
      .banner-wrap img { height: 140px; }
    }
  </style>
</head>
